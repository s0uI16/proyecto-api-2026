# Puerto en el que corre el servidor Express
PORT=3000

# Cadena de conexión a PostgreSQL
# formato: postgresql://usuario:password@host:puerto/nombre_bd?schema=public
DATABASE_URL="postgresql://usuario:password@localhost:5432/nombre_bd?schema=public"

# Entorno de ejecución: development | production | test
NODE_ENV=development

# Secreto usado para firmar los JWT (HS256) con la librería `jose`.
# OBLIGATORIO en producción. En desarrollo, si se omite, se usa un fallback
# inseguro solo para no bloquear el trabajo local (ver src/config/jwt.js).
JWT_SECRET="cambia-este-secreto-por-uno-largo-y-aleatorio"

# Lista blanca de orígenes permitidos para CORS, separados por coma.
# El propio frontend servido desde /public es del mismo origen y siempre
# está permitido; esto es para clientes externos (ej. un frontend aparte).
CORS_ORIGINS="http://localhost:3000"
